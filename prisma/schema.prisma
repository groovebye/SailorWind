generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Ports & Marinas ──────────────────────────────────────────────

model Port {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  lat       Float
  lon       Float
  type      PortType
  country   String
  region    String?

  // Facilities
  fuel      Boolean  @default(false)
  water     Boolean  @default(false)
  electric  Boolean  @default(false)
  repairs   Boolean  @default(false)
  customs   Boolean  @default(false)

  // Metadata
  shelter   String?  // "good", "moderate", "poor"
  maxDraft  Float?   // meters
  vhfCh    String?
  website   String?
  phone     String?
  email     String?
  notes     String?

  // Marina details
  marinaName     String?
  marinaHours    String?   // "Mon-Sun 09:00-21:00"
  berthCount     Int?
  visitorBerths  Int?
  maxLength      Float?    // meters
  accessCodes    String?   // "Showers: 1234, WC: 5678"
  approachNotes  String?   // "Enter on red buoy, 3m min depth"

  // Nearby services (JSON arrays)
  restaurants    Json?     // [{name, rating, cuisine, phone, hours, address, description}]
  yachtShops     Json?     // [{name, phone, hours, address, description}]
  groceryStores  Json?     // [{name, phone, hours, address, description}]

  // Port classification
  tier           String?   // "major" | "medium" | "minor"
  // major = large marina, full services, crew change port
  // medium = decent marina, visitor berths, basic services
  // minor = small port, limited, bail-out only

  // Safety
  orcaRisk       String?   // "none" | "low" | "medium" | "high"
  orcaNotes      String?

  // Passage descriptions for legs ending at this port
  approachDescription String? // detailed approach text
  passageNotes        String? // general sailing notes for this area

  // Shore services (JSON arrays beyond restaurants/shops)
  extras             Json?     // [{category, name, phone, hours, address, description}]
  // categories: "atm", "pharmacy", "hospital", "laundry", "gas_refill",
  //             "taxi", "bus", "hardware", "bakery", "fish_market"

  // Marina facilities detail
  marinaFacilities   Json?     // {showers: bool, laundry: bool, wifi: bool, ...}

  // Source verification for key fields
  sourceVerification Json?     // {phone: {source, url, checkedAt}, hours: {...}, ...}

  // Coastline ordering (distance in NM from a reference point along coast)
  // Used to order ports between two points and estimate distances
  coastSegment  String   // e.g. "biscay-north", "galicia-west", "portugal"
  coastlineNm   Float    // cumulative NM along this segment

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  passagePorts  PassagePort[]
  waypointsOf   PassageWaypoint[]

  @@index([coastSegment, coastlineNm])
  @@index([country])
  @@index([lat, lon])
}

enum PortType {
  marina
  port
  anchorage
  cape
}

// ── Passages ─────────────────────────────────────────────────────

model Passage {
  id          String   @id @default(cuid())
  shortId     String   @unique @default(cuid()) // for shareable URLs
  name        String?

  departure   DateTime
  speed       Float    @default(5.0)
  mode        PassageMode @default(daily)
  model       String   @default("ecmwf_ifs025")
  source      String   @default("openmeteo")  // "openmeteo" | "windy"

  // Cached forecasts — keyed by "{source}_{model}": { data: {...}, cachedAt: ISO }
  forecastCache Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ports        PassagePort[]
  waypoints    PassageWaypoint[]
  computations LegComputation[]
  legRoutes    PassageLegRoute[]
  executions   PassageExecution[]
}

enum PassageMode {
  daily
  nonstop
}

// ── Learning / Memory ───────────────────────────────────────────

model LegMemory {
  id          String   @id @default(cuid())
  fromSlug    String
  toSlug      String
  note        String
  category    String   // "weather", "timing", "comfort", "hazard", "approach", "general"
  severity    String?  // "info" | "warning" | "critical"
  source      String?  // "debrief" | "manual" | "observation"
  recordedAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([fromSlug, toSlug])
}

model PortMemory {
  id          String   @id @default(cuid())
  portSlug    String
  note        String
  category    String   // "approach", "berth", "shore", "hazard", "general"
  severity    String?
  source      String?
  recordedAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([portSlug])
}

// ── Maintenance / Readiness ─────────────────────────────────────

model MaintenanceItem {
  id          String   @id @default(cuid())
  vesselSlug  String   @default("bossanova")
  title       String
  category    String   // "engine", "rigging", "safety", "hull", "electronics", "general"
  status      String   @default("ok") // "ok" | "due" | "overdue" | "done"
  dueDate     DateTime?
  engineHoursDue Int?
  lastDoneAt  DateTime?
  note        String?
  priority    String?  // "low" | "medium" | "high" | "critical"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([vesselSlug, status])
}

// ── Manual Route Overrides ──────────────────────────────────────

model PassageLegRoute {
  id          String   @id @default(cuid())
  passage     Passage  @relation(fields: [passageId], references: [id], onDelete: Cascade)
  passageId   String
  legIndex    Int
  mode        String   @default("auto") // "auto" | "manual"
  name        String?
  notes       String?
  distanceNm  Float?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  points      PassageLegRoutePoint[]

  @@unique([passageId, legIndex])
  @@index([passageId])
}

model PassageLegRoutePoint {
  id          String   @id @default(cuid())
  route       PassageLegRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  routeId     String
  sortOrder   Int
  lat         Float
  lon         Float
  label       String?
  kind        String?  // "departure" | "manual" | "cape_rounding" | "arrival"

  @@index([routeId, sortOrder])
}

// ── Live Passage Execution ──────────────────────────────────────

model PassageExecution {
  id          String   @id @default(cuid())
  passage     Passage  @relation(fields: [passageId], references: [id], onDelete: Cascade)
  passageId   String
  legIndex    Int
  status      String   @default("planned") // "planned" | "active" | "completed" | "aborted"
  startedAt   DateTime?
  endedAt     DateTime?
  name        String?
  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trackPoints   PassageExecutionTrackPoint[]
  checkpoints   PassageExecutionCheckpoint[]
  observations  PassageExecutionObservation[]

  @@index([passageId, legIndex])
}

model PassageExecutionTrackPoint {
  id            String   @id @default(cuid())
  execution     PassageExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  executionId   String
  recordedAt    DateTime
  lat           Float
  lon           Float
  sogKt         Float?
  cogDeg        Float?
  headingDeg    Float?
  mode          String?  // "sail" | "motor" | "motorsail"
  engineOn      Boolean?
  reefLevel     Int?
  note          String?

  createdAt     DateTime @default(now())

  @@index([executionId, recordedAt])
}

model PassageExecutionCheckpoint {
  id            String   @id @default(cuid())
  execution     PassageExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  executionId   String
  recordedAt    DateTime
  lat           Float?
  lon           Float?
  type          String   // "departure" | "cape" | "reef_in" | "reef_out" | "bailout_decision" | "harbor_approach" | "arrival" | "custom"
  title         String
  note          String?

  createdAt     DateTime @default(now())

  @@index([executionId, recordedAt])
}

model PassageExecutionObservation {
  id                String   @id @default(cuid())
  execution         PassageExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  executionId       String
  recordedAt        DateTime
  lat               Float?
  lon               Float?
  observedWindKt    Float?
  observedWindDirDeg Float?
  observedWaveM     Float?
  observedSwellM    Float?
  seaStateText      String?
  visibilityNm      Float?
  barometerHpa      Float?
  sailConfig        String?
  comfort           String?  // "comfortable" | "moderate" | "bumpy" | "demanding" | "hard_work"
  note              String?

  createdAt         DateTime @default(now())

  @@index([executionId, recordedAt])
}

// ── Leg Guides (curated pilotage knowledge) ─────────────────────

model LegGuide {
  id            String  @id @default(cuid())
  fromSlug      String  // port slug: "gijon"
  toSlug        String  // port slug: "luarca"

  // Pilotage summary
  difficulty    String?  // "easy" | "moderate" | "challenging" | "dangerous"
  description   String?  // Brief leg description
  pilotageText  String?  // Full pilotage notes (markdown)

  // Milestones JSON array
  // [{name, lat, lon, eta_offset_hours, bearing, visual_ref, notes, type}]
  // types: "departure", "clear_breakwater", "course_change", "round_cape", "approach", "berth"
  milestones    Json?

  // Hazards JSON array
  // [{name, lat, lon, type, severity, description, visual_ref}]
  // types: "shoal", "rock", "current", "wind_acceleration", "traffic", "military"
  hazards       Json?

  // Fallback ports JSON array
  // [{name, slug, distance_nm, time_hours, conditions}]
  fallbackPorts Json?

  // Tidal info
  tidalNotes    String?  // "Tidal range 3.5m at springs. Enter Ribadeo +/- 2h HW"
  tidalGate     String?  // "Depart Luarca HW-1 to HW+3 for fair tide"

  // Current info
  currentNotes  String?

  // Best departure window
  bestWindow    String?  // "Early morning 06:00-08:00, offshore breeze"

  // Night sailing notes
  nightNotes    String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([fromSlug, toSlug])
}

// ── Port Areas & Marina Options (content layer) ────────────────

model PortArea {
  id              String   @id @default(cuid())
  name            String   // "La Coruña"
  slug            String   @unique
  country         String
  region          String?
  lat             Float
  lon             Float
  type            String   // "major_stopover" | "medium_stopover" | "minor_stopover" | "cape_area"

  description         String?
  arrivalSummary      String?
  shoreSummary        String?
  repairSummary       String?
  provisioningSummary String?

  // Shore services (shared across all marinas in this area)
  restaurants    Json?
  yachtShops     Json?
  groceryStores  Json?
  extras         Json?

  // Safety
  orcaRisk       String?
  orcaNotes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  marinas      MarinaOption[]
  nearbyPlaces NearbyPlace[]
}

model MarinaOption {
  id            String   @id @default(cuid())
  portArea      PortArea @relation(fields: [portAreaId], references: [id], onDelete: Cascade)
  portAreaId    String
  name          String   // "Marina Coruña"
  slug          String   @unique
  operator      String?
  lat           Float
  lon           Float
  kind          String   // "marina" | "yacht_club" | "fishing_port" | "mixed_port"

  website       String?
  email         String?
  phone         String?
  vhfCh         String?

  shelter       String?  // "good" | "moderate" | "poor"
  maxDraft      Float?
  maxLength     Float?
  berthCount    Int?
  visitorBerths Int?

  fuel          Boolean  @default(false)
  water         Boolean  @default(false)
  electric      Boolean  @default(false)
  repairs       Boolean  @default(false)
  laundry       Boolean  @default(false)
  showers       Boolean  @default(false)
  toilets       Boolean  @default(false)
  wifi          Boolean  @default(false)
  customs       Boolean  @default(false)
  securityGate  Boolean  @default(false)
  pumpOut       Boolean  @default(false)

  marinaHours         String?
  approachDescription String?
  entranceNotes       String?
  waitingArea         String?
  bestTideEntry       String?
  swellSensitivity    String?
  notes               String?

  sourceVerification  Json?

  // Extended marina intelligence
  sizeLabel       String?  // "Small" | "Medium" | "Large" | "Major"
  cityWalkMinutes Int?
  bestFor         String?  // "budget, transient, repairs, provisioning"
  drawbacks       String?
  fuelNotes       String?
  visitorBerthNotes String?
  berthingNotes   String?
  exitNotes       String?
  officialLayoutImageUrl String?
  officialLayoutPdfUrl   String?
  officialLayoutSource   String?
  officialLayoutCheckedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prices       MarinaPrice[]
  mapFeatures  MarinaMapFeature[]
  nearbyPlaces NearbyPlace[]
}

model MarinaPrice {
  id              String   @id @default(cuid())
  marina          MarinaOption @relation(fields: [marinaOptionId], references: [id], onDelete: Cascade)
  marinaOptionId  String

  loaMeters       Float    @default(9.5)
  season          String   // "low" | "high"
  billingPeriod   String   // "daily" | "monthly"
  price           Float
  currency        String   @default("EUR")
  taxIncluded     Boolean  @default(true)
  utilitiesIncluded Boolean @default(false)
  pricingNote     String?

  sourceName      String?
  sourceUrl       String?
  checkedAt       DateTime?
  confidence      String?  // "official" | "curated" | "estimated"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([marinaOptionId])
}

model MarinaMapFeature {
  id              String   @id @default(cuid())
  marina          MarinaOption @relation(fields: [marinaOptionId], references: [id], onDelete: Cascade)
  marinaOptionId  String

  type            String   // "breakwater" | "entrance" | "waiting_area" | "visitor_berth" | "fuel_dock" | "office" | "showers" | "hazard" | "route_hint"
  name            String
  geometry        Json     // GeoJSON geometry
  description     String?
  sortOrder       Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([marinaOptionId])
}

model NearbyPlace {
  id              String   @id @default(cuid())
  portArea        PortArea @relation(fields: [portAreaId], references: [id], onDelete: Cascade)
  portAreaId      String
  marina          MarinaOption? @relation(fields: [marinaOptionId], references: [id], onDelete: SetNull)
  marinaOptionId  String?

  name            String
  category        String   // restaurant, chandlery, grocery, pharmacy, laundry, atm, etc.
  subcategory     String?
  description     String?
  address         String?
  phone           String?
  website         String?
  hours           String?
  lat             Float?
  lon             Float?

  distanceMeters  Int?
  walkMinutes     Int?
  rating          Float?
  reviewCount     Int?
  priceLevel      String?  // "$" | "$$" | "$$$"
  isRecommended   Boolean  @default(false)
  bestFor         String?

  sourceName      String?
  sourceUrl       String?
  checkedAt       DateTime?
  confidence      String?  // "official" | "curated" | "estimated"
  notes           String?
  sortOrder       Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([portAreaId, category])
  @@index([marinaOptionId, category])
}

model VesselProfile {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  loaMeters       Float
  draftMeters     Float
  engineCruiseKt  Float
  engineMaxKt     Float?

  // Fuel system
  fuelBurnLph       Float?    // liters per hour at cruise RPM
  fuelTankLiters    Float?    // total tank capacity
  usableFuelLiters  Float?    // usable fuel (minus reserve)
  reserveFuelLiters Float?    // minimum reserve to keep
  motorsailBurnLph  Float?    // fuel burn when motorsailing

  notes           String?
  performanceModel Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  computations    LegComputation[]
}

model LegComputation {
  id                String   @id @default(cuid())
  passage           Passage  @relation(fields: [passageId], references: [id], onDelete: Cascade)
  passageId         String
  legIndex          Int
  vessel            VesselProfile @relation(fields: [vesselProfileId], references: [id])
  vesselProfileId   String
  forecastSignature String
  routeSignature    String
  vesselSignature   String
  summary           Json
  timeline          Json
  warnings          Json?
  status            String   @default("ready")
  computedAt        DateTime @default(now())
  validUntil        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([passageId, legIndex, forecastSignature, routeSignature, vesselSignature])
  @@index([passageId, legIndex, updatedAt])
}

// Junction: which ports are start/end of this passage
model PassagePort {
  id         String  @id @default(cuid())
  passage    Passage @relation(fields: [passageId], references: [id], onDelete: Cascade)
  passageId  String
  port       Port    @relation(fields: [portId], references: [id])
  portId     String
  role       String  // "start", "end"

  @@unique([passageId, role])
}

// All waypoints/stops in order for a passage
model PassageWaypoint {
  id         String  @id @default(cuid())
  passage    Passage @relation(fields: [passageId], references: [id], onDelete: Cascade)
  passageId  String
  port       Port    @relation(fields: [portId], references: [id])
  portId     String

  sortOrder  Int
  isStop     Boolean @default(false) // true = overnight stop (leg boundary)
  isCape     Boolean @default(false) // auto-included for weather monitoring

  @@unique([passageId, sortOrder])
  @@index([passageId])
}
