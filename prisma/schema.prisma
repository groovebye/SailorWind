generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Ports & Marinas ──────────────────────────────────────────────

model Port {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  lat       Float
  lon       Float
  type      PortType
  country   String
  region    String?

  // Facilities
  fuel      Boolean  @default(false)
  water     Boolean  @default(false)
  electric  Boolean  @default(false)
  repairs   Boolean  @default(false)
  customs   Boolean  @default(false)

  // Metadata
  shelter   String?  // "good", "moderate", "poor"
  maxDraft  Float?   // meters
  vhfCh    String?
  website   String?
  phone     String?
  email     String?
  notes     String?

  // Marina details
  marinaName     String?
  marinaHours    String?   // "Mon-Sun 09:00-21:00"
  berthCount     Int?
  visitorBerths  Int?
  maxLength      Float?    // meters
  accessCodes    String?   // "Showers: 1234, WC: 5678"
  approachNotes  String?   // "Enter on red buoy, 3m min depth"

  // Nearby services (JSON arrays)
  restaurants    Json?     // [{name, rating, cuisine, phone, hours, address, description}]
  yachtShops     Json?     // [{name, phone, hours, address, description}]
  groceryStores  Json?     // [{name, phone, hours, address, description}]

  // Port classification
  tier           String?   // "major" | "medium" | "minor"
  // major = large marina, full services, crew change port
  // medium = decent marina, visitor berths, basic services
  // minor = small port, limited, bail-out only

  // Safety
  orcaRisk       String?   // "none" | "low" | "medium" | "high"
  orcaNotes      String?

  // Passage descriptions for legs ending at this port
  approachDescription String? // detailed approach text
  passageNotes        String? // general sailing notes for this area

  // Shore services (JSON arrays beyond restaurants/shops)
  extras             Json?     // [{category, name, phone, hours, address, description}]
  // categories: "atm", "pharmacy", "hospital", "laundry", "gas_refill",
  //             "taxi", "bus", "hardware", "bakery", "fish_market"

  // Marina facilities detail
  marinaFacilities   Json?     // {showers: bool, laundry: bool, wifi: bool, ...}

  // Source verification for key fields
  sourceVerification Json?     // {phone: {source, url, checkedAt}, hours: {...}, ...}

  // Coastline ordering (distance in NM from a reference point along coast)
  // Used to order ports between two points and estimate distances
  coastSegment  String   // e.g. "biscay-north", "galicia-west", "portugal"
  coastlineNm   Float    // cumulative NM along this segment

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  passagePorts  PassagePort[]
  waypointsOf   PassageWaypoint[]

  @@index([coastSegment, coastlineNm])
  @@index([country])
  @@index([lat, lon])
}

enum PortType {
  marina
  port
  anchorage
  cape
}

// ── Passages ─────────────────────────────────────────────────────

model Passage {
  id          String   @id @default(cuid())
  shortId     String   @unique @default(cuid()) // for shareable URLs
  name        String?

  departure   DateTime
  speed       Float    @default(5.0)
  mode        PassageMode @default(daily)
  model       String   @default("ecmwf_ifs025")
  source      String   @default("openmeteo")  // "openmeteo" | "windy"

  // Cached forecasts — keyed by "{source}_{model}": { data: {...}, cachedAt: ISO }
  forecastCache Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ports       PassagePort[]
  waypoints   PassageWaypoint[]
}

enum PassageMode {
  daily
  nonstop
}

// ── Leg Guides (curated pilotage knowledge) ─────────────────────

model LegGuide {
  id            String  @id @default(cuid())
  fromSlug      String  // port slug: "gijon"
  toSlug        String  // port slug: "luarca"

  // Pilotage summary
  difficulty    String?  // "easy" | "moderate" | "challenging" | "dangerous"
  description   String?  // Brief leg description
  pilotageText  String?  // Full pilotage notes (markdown)

  // Milestones JSON array
  // [{name, lat, lon, eta_offset_hours, bearing, visual_ref, notes, type}]
  // types: "departure", "clear_breakwater", "course_change", "round_cape", "approach", "berth"
  milestones    Json?

  // Hazards JSON array
  // [{name, lat, lon, type, severity, description, visual_ref}]
  // types: "shoal", "rock", "current", "wind_acceleration", "traffic", "military"
  hazards       Json?

  // Fallback ports JSON array
  // [{name, slug, distance_nm, time_hours, conditions}]
  fallbackPorts Json?

  // Tidal info
  tidalNotes    String?  // "Tidal range 3.5m at springs. Enter Ribadeo +/- 2h HW"
  tidalGate     String?  // "Depart Luarca HW-1 to HW+3 for fair tide"

  // Current info
  currentNotes  String?

  // Best departure window
  bestWindow    String?  // "Early morning 06:00-08:00, offshore breeze"

  // Night sailing notes
  nightNotes    String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([fromSlug, toSlug])
}

// Junction: which ports are start/end of this passage
model PassagePort {
  id         String  @id @default(cuid())
  passage    Passage @relation(fields: [passageId], references: [id], onDelete: Cascade)
  passageId  String
  port       Port    @relation(fields: [portId], references: [id])
  portId     String
  role       String  // "start", "end"

  @@unique([passageId, role])
}

// All waypoints/stops in order for a passage
model PassageWaypoint {
  id         String  @id @default(cuid())
  passage    Passage @relation(fields: [passageId], references: [id], onDelete: Cascade)
  passageId  String
  port       Port    @relation(fields: [portId], references: [id])
  portId     String

  sortOrder  Int
  isStop     Boolean @default(false) // true = overnight stop (leg boundary)
  isCape     Boolean @default(false) // auto-included for weather monitoring

  @@unique([passageId, sortOrder])
  @@index([passageId])
}
